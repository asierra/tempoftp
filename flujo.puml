@startuml
skinparam Monochrome true
skinparam shadowing false

title Flujo de Trabajo - Sistema tempoftp

start

:Recepción de solicitud (POST /tmpftp);
note right
  Datos: usuario, id, ruta, vigencia
end note

:Establecer estado: **recibido**;
:Validar y registrar en SQLite;

partition "Preparación" {
    :Preparar directorio y permisos;
    if (¿La ruta es local?) then (no)
        :Verificar espacio disponible;
        :Estado: **preparando**;
        
        partition "Proceso Asíncrono (rsync)" {
            :Ejecutar rsync en segundo plano;
            :Estado: **trasladando**;
            if (¿Rsync exitoso?) then (sí)
                :Estado: **trasladado**;
            else (error)
                :Estado: **error**;
                stop
            endif
        }
    else (sí)
        if (¿Ruta existe?) then (no)
            :Estado: **error**;
            stop
        endif
    endif
}

partition "Activación FTP" {
    :Crear usuario en MySQL (Pure-FTPd);
    note right: Contraseña cifrada con Argon2
    :Almacenar credenciales en SQLite;
    :Estado: **ready**;
}

:Usuario consulta estado (GET /tmpftp/{id});

-[dotted]->
:Tarea programada (Vigencia expirada);
:Eliminar usuario FTP y datos;

stop
@enduml
