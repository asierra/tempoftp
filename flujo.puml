@startuml
skinparam Monochrome true
skinparam shadowing false

title Flujo de Trabajo - Sistema tempoftp

start

partition "Inicial" {
    :POST /tmpftp;
    note right
      usuario, id, ruta
      vigencia (default: 10 días)
    end note
    :Validar y registrar en SQLite;
    :Estado: **recibido**;
}

partition "Preparación" {
    :Estado: **preparando**;
    :Preparar directorio y permisos;
    if (¿Ruta local?) then (sí)
        :Crear enlace simbólico;
    else (no)
        :Verificar espacio disponible;
        :Estado: **traslado**;
        :Ejecutar rsync;
        if (¿Rsync exitoso?) then (sí)
        else (error)
            :Estado: **error**;
            stop
        endif
    endif
}

partition "Activación FTP" {
    if (¿Usuario existe en MySQL?) then (sí)
        :Actualizar contraseña;
    else (no)
        :Crear usuario en MySQL;
    endif
    :Almacenar credenciales en SQLite;
    :Estado: **listo**;
    :GET /tmpftp/{id};
    note right
      Credenciales FTP +
      estadísticas de descargas
    end note
    -[dotted]->
    :Vigencia expirada: eliminar usuario y datos;
}

stop
@enduml
